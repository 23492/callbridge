# === AssemblyAI ===
# API key for the AssemblyAI v2 transcription service used for speaker diarisation.
# Obtain from your AssemblyAI dashboard at https://www.assemblyai.com
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# === Google Gemini ===
# API key for call-summary generation and action-item extraction via the Gemini API.
# Obtain from Google AI Studio at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# === Salesforce ===
# Credentials to authenticate against the Welisa production Salesforce org via simple_salesforce.
# All four variables are required; the org authenticates using username + password + security token.

# Your Salesforce login email address.
SF_USERNAME=your-salesforce-username@welisa.com

# Your Salesforce account password.
SF_PASSWORD=your-salesforce-password

# Per-user security token appended to the password for API login.
# Reset at: Salesforce → Settings → My Personal Information → Reset My Security Token.
SF_SECURITY_TOKEN=your-salesforce-security-token

# Salesforce org subdomain. Leave as "welisa" for the Welisa production org.
# Change only if connecting to a sandbox (e.g. "welisa--staging").
SF_DOMAIN=welisa

# === Release signing ===
# Ed25519 base64-encoded private key consumed by sign-update.swift during build-release.sh runs.
# Required ONLY for the release maintainer who cuts new CallBridge releases.
# End users and contributors who do not cut releases do not need this variable.
# Generate a keypair with: swift sign-update.swift --generate (or equivalent CryptoKit tooling).
SIGNING_PRIVATE_KEY=your-ed25519-base64-private-key
